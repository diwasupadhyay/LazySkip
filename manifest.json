{
  "manifest_version": 3,
  "name": "LazySkip",
  "version": "1.0.0",
  "description": "Auto-skip intros and recaps, auto-play the next episode, and speed up ads on Netflix and Amazon Prime Video. Built with laziness.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LazySkip"
  },
  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["core.js", "netflix.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.primevideo.com/*"],
      "js": ["core.js", "prime.js"],
      "run_at": "document_idle"
    }
  ]
}
